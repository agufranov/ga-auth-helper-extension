{
  "manifest_version": 3,
  "name": "GA Auth Helper",
  "description": "Helper extension for developers and QA engineers.",
  "version": "0.1.0",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_title": "GA Auth Helper",
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "background": {
    "service_worker": "src/background.ts"
  },
  "content_scripts": [
    {
      "matches": [
        "*://*.goldapple.ru/*",
        "*://goldapple.ru/*",
        "*://*.goldapple.by/*",
        "*://goldapple.by/*",
        "*://*.goldapple.kz/*",
        "*://goldapple.kz/*",
        "*://*.goldapple.ae/*",
        "*://goldapple.ae/*",
        "*://*.goldapple.cn/*",
        "*://goldapple.cn/*",
        "*://*.goldapple.qa/*",
        "*://goldapple.qa/*",
        "*://*.goldapple.sa/*",
        "*://goldapple.sa/*",
        "*://localhost:*/*",
        "*://0.0.0.0:*/*",
        "*://127.0.0.1:*/*"
      ],
      "exclude_matches": [
        "*://portal.goldapple.ru/*",
        "*://portal.goldapple.by/*",
        "*://portal.goldapple.kz/*",
        "*://portal.goldapple.ae/*",
        "*://portal.goldapple.cn/*",
        "*://portal.goldapple.qa/*",
        "*://portal.goldapple.sa/*",
        "*://jira01.goldapple.ru/*",
        "*://jira01.goldapple.by/*",
        "*://jira01.goldapple.kz/*",
        "*://jira01.goldapple.ae/*",
        "*://jira01.goldapple.cn/*",
        "*://jira01.goldapple.qa/*",
        "*://jira01.goldapple.sa/*",
        "*://git.goldapple.ru/*",
        "*://git.goldapple.by/*",
        "*://git.goldapple.kz/*",
        "*://git.goldapple.ae/*",
        "*://git.goldapple.cn/*",
        "*://git.goldapple.qa/*",
        "*://git.goldapple.sa/*",
        "*://confluence.goldapple.ru/*",
        "*://confluence.goldapple.by/*",
        "*://confluence.goldapple.kz/*",
        "*://confluence.goldapple.ae/*",
        "*://confluence.goldapple.cn/*",
        "*://confluence.goldapple.qa/*",
        "*://confluence.goldapple.sa/*",
        "*://owa.goldapple.ru/*",
        "*://owa.goldapple.by/*",
        "*://owa.goldapple.kz/*",
        "*://owa.goldapple.ae/*",
        "*://owa.goldapple.cn/*",
        "*://owa.goldapple.qa/*",
        "*://owa.goldapple.sa/*",
        "*://jitsi.goldapple.ru/*",
        "*://jitsi.goldapple.by/*",
        "*://jitsi.goldapple.kz/*",
        "*://jitsi.goldapple.ae/*",
        "*://jitsi.goldapple.cn/*",
        "*://jitsi.goldapple.qa/*",
        "*://jitsi.goldapple.sa/*",
        "*://mm.goldapple.ru/*",
        "*://mm.goldapple.by/*",
        "*://mm.goldapple.kz/*",
        "*://mm.goldapple.ae/*",
        "*://mm.goldapple.cn/*",
        "*://mm.goldapple.qa/*",
        "*://mm.goldapple.sa/*"
      ],
      "js": ["src/content/main.ts"],
      "run_at": "document_idle"
    }
  ],
  "permissions": ["storage", "tabs"],
  "host_permissions": [
    "*://*.goldapple.ru/*",
    "*://goldapple.ru/*",
    "*://*.goldapple.by/*",
    "*://goldapple.by/*",
    "*://*.goldapple.kz/*",
    "*://goldapple.kz/*",
    "*://*.goldapple.ae/*",
    "*://goldapple.ae/*",
    "*://*.goldapple.cn/*",
    "*://goldapple.cn/*",
    "*://*.goldapple.qa/*",
    "*://goldapple.qa/*",
    "*://*.goldapple.sa/*",
    "*://goldapple.sa/*",
    "*://localhost:*/*",
    "*://0.0.0.0:*/*",
    "*://127.0.0.1:*/*"
  ]
}
